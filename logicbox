#!/usr/bin/env zsh
set -euo pipefail

ROOT="${0:A:h}"
SHEN="${SHEN_SBCL:-/opt/homebrew/bin/shen-sbcl}"
WORK="$ROOT/work"
OUT="$ROOT/output"
FACTS="$WORK/ai-facts.shen"
ADAPTER_FACTS="$WORK/adapter-facts.shen"
REWRITE_FACTS="$WORK/rewrite-facts.shen"
REWRITE_PATCH="$WORK/rewrite-patch.json"
REWRITE="$WORK/rewrite.md"
PREFLIGHT_FACTS="$OUT/.preflight-facts.shen"
REWRITE_REPORT="$OUT/rewrite-report.md"
SHEN_BEFORE_REWRITE="$OUT/shen-before-rewrite.txt"
CHECK_REPORT="$OUT/check-report.md"
SCHEMA_ARGS=(
  -l "$ROOT/shen/fact-schema.shen"
  -l "$ROOT/shen/fact-normalize.shen"
  -l "$ROOT/shen/fact-provenance.shen"
  -l "$ROOT/shen/fact-typecheck.shen"
)

usage() {
  cat <<'EOF'
LogicBox

Usage:
  ./logicbox preflight
  ./logicbox review
  ./logicbox check
  ./logicbox mutation
  ./logicbox rewrite-preflight
  ./logicbox rewrite
  ./logicbox rewrite-mutation
  ./logicbox recheck-report
  ./logicbox rewrite-test
  ./logicbox report-smoke
  ./logicbox schema-contract
  ./logicbox schema-test
  ./logicbox test
  ./logicbox stress
  ./logicbox gold
  ./logicbox edge
  ./logicbox fuzz
  ./logicbox new "Your draft claim here"
  ./logicbox show

Workflow:
  1. Put prose in work/draft.txt.
  2. Put AI-proposed symbolic facts in work/ai-facts.shen.
  3. Put temporary semantic bridge facts in work/adapter-facts.shen when needed.
  4. Run ./logicbox review for the streamlined report.
  5. Read output/check-report.md first; output/shen-output.txt is the expert/audit view.

For safe prose rewrites, put a rewrite patch in work/rewrite-patch.json
and run ./logicbox rewrite. For symbolic rewrite checks, put rewrite-derived
facts in work/rewrite-facts.shen and run ./logicbox mutation.

The checker is Shen. The wrapper runs Shen, keeps raw output for audit, and renders a source-facing report.
EOF
}

ensure_dirs() {
  mkdir -p "$WORK" "$OUT"
}

capture_logicbox_output() {
  local raw="$1"
  local dest="$2"
  awk '
    /^LOGICBOX-BEGIN$/ {capture=1; next}
    /^LOGICBOX-END$/ {capture=0; exit}
    capture && $0 !~ /^"/ && $0 != "ok" {print}
  ' "$raw" > "$dest"
}

run_check_model() {
  local model="$1"
  local raw="$2"
  local out="$3"
  "$SHEN" \
    -l "$model" \
    "${SCHEMA_ARGS[@]}" \
    -l "$ROOT/shen/rules.shen" \
    -l "$ROOT/shen/run.shen" \
    > "$raw"
  capture_logicbox_output "$raw" "$out"
}

use_legacy_js_preflight() {
  [[ " $* " == *" --legacy-js-preflight "* ]]
}

rewrite_safety_args() {
  if [[ " $* " == *" --legacy-js-rewrite-safety "* ]]; then
    echo "--legacy-js-rewrite-safety"
  fi
}

run_native_preflight() {
  local dest="$1"
  shift
  local -a adapter_args
  adapter_args=()
  if [[ -f "$ADAPTER_FACTS" ]]; then
    adapter_args=(-l "$ADAPTER_FACTS")
  fi
  "$SHEN" \
    "$@" \
    -l "$ROOT/shen/rules.shen" \
    "${adapter_args[@]}" \
    -l "$ROOT/shen/run-preflight.shen" \
    > "$OUT/.shen-preflight-raw-output.txt"
  capture_logicbox_output "$OUT/.shen-preflight-raw-output.txt" "$dest"
}

render_fact_lines() {
  local file="$1"
  local mode="$2"
  if [[ ! -f "$file" ]]; then
    echo "- none"
    return
  fi
  awk -v mode="$mode" '
    /^[[:space:]]*\[[^]]+\]/ {
      line=$0
      sub(/^[[:space:]]*/, "", line)
      isUser = line ~ /^\[user-supplied[[:space:]]/
      isAdapter = line ~ /^\[adapter-/
      if (mode == "source" && !isUser && !isAdapter) { print "- " line; count++ }
      if (mode == "user" && isUser) { print "- " line; count++ }
      if (mode == "adapter") { print "- " line; count++ }
    }
    END {
      if (count == 0) print "- none"
    }
  ' "$file" | sed '/^$/d'
}

render_flag_category() {
  local flags="$1"
  local mode="$2"
  if [[ ! -f "$flags" ]]; then
    echo "- none"
    return
  fi
  awk -v mode="$mode" '
    function add(line) { print "- " line; count++ }
    /^\[/ {
      isPlan = $0 ~ /^\[plan-status /
      isPositive = $0 ~ /^\[value-criteria-grounded / || $0 ~ /^\[value-criteria-stated /
      isEvidence = $0 ~ /^\[evidence-needed /
      isValueOpen = $0 ~ /^\[value-criteria-missing / || $0 ~ /^\[value-criteria-needed /
      isContext = $0 ~ /^\[missing-context /
      isDefinition = $0 ~ /^\[definition-needed /
      isBlocking = $0 ~ /^\[fact-type-error / ||
        $0 ~ /^\[contradiction / ||
        isDefinition ||
        isContext ||
        $0 ~ /^\[overclaim / ||
        $0 ~ /^\[deleted-/ ||
        $0 ~ /^\[mutation-violation / ||
        $0 ~ /^\[patch-violation /
      isTension = $0 ~ /^\[tension / || $0 ~ /^\[mitigation-needs-equivalence-check /

      if (mode == "blocking" && isBlocking) add($0)
      if (mode == "tensions" && isTension) add($0)
      if (mode == "tasks" && (isEvidence || isDefinition || isContext || isValueOpen)) add($0)
      if (mode == "positive" && isPositive) add($0)
      if (mode == "status" && isPlan) add($0)
    }
    END {
      if (count == 0) print "- none"
    }
  ' "$flags"
}

render_open_task_facts() {
  local file="$1"
  if [[ ! -f "$file" ]]; then
    return
  fi
  awk '
    /^[[:space:]]*\[open-task / {
      line=$0
      n=split(line, parts, "\"")
      if (n >= 3) {
        print "- " parts[2]
      } else {
        sub(/^[[:space:]]*/, "", line)
        print "- " line
      }
      count++
    }
  ' "$file"
}

render_open_user_tasks() {
  local flags="$1"
  {
    render_open_task_facts "$FACTS"
    render_open_task_facts "$ADAPTER_FACTS"
    render_flag_category "$flags" tasks
  } | awk '
    $0 == "- none" { next }
    !seen[$0] { print; seen[$0] = 1; count++ }
    END {
      if (count == 0) print "- none"
    }
  '
}

render_next_action() {
  local flags="$1"
  if [[ ! -f "$flags" ]]; then
    echo "- Run ./logicbox review after adding candidate facts."
    return
  fi
  awk '
    /^\[plan-status / {
      if ($0 ~ / translation-error\]$/) status = "translation-error"
      else if ($0 ~ / needs-reconciliation\]$/) status = "needs-reconciliation"
      else if ($0 ~ / needs-evidence\]$/) status = "needs-evidence"
      else if ($0 ~ / awaiting-value-confirmation\]$/) status = "awaiting-value-confirmation"
      else if ($0 ~ / needs-user-input\]$/) status = "needs-user-input"
      else if ($0 ~ / ready-for-final-rewrite\]$/) status = "ready-for-final-rewrite"
    }
    /^\[fact-type-error / || /^\[extraction-contract-violation / || /^\[decomposition-needed / { translation = 1 }
    /^\[contradiction / || /^\[tension / || /^\[mitigation-needs-equivalence-check / { reconciliation = 1 }
    /^\[missing-context / || /^\[definition-needed / || /^\[missing-mechanism / ||
      /^\[unclear-scope / || /^\[unclear-modality / || /^\[claim-without-ground / { user = 1 }
    /^\[evidence-needed / { evidence = 1 }
    END {
      if (translation || status == "translation-error") {
        print "- Repair the translation/fact shape before judging the argument."
      } else if (reconciliation || status == "needs-reconciliation") {
        print "- Reconcile the accepted commitments that now conflict or pull against each other."
      } else if (evidence || status == "needs-evidence") {
        print "- Decide whether to supply evidence, narrow the claim, or mark the evidence gap."
      } else if (user || status == "needs-user-input" || status == "awaiting-value-confirmation") {
        print "- Ask for the missing definition, context, mechanism, scope, support, or value criterion."
      } else if (status == "ready-for-final-rewrite") {
        print "- No blocking structural diagnostics. A conservative rewrite can be prepared if desired."
      } else {
        print "- Inspect the diagnostics below, then update facts or ask one focused clarification question."
      }
    }
  ' "$flags"
}

render_file_map() {
  echo "- Read first: output/check-report.md"
  echo "- Human draft: work/draft.txt"
  echo "- AI translation: work/ai-facts.shen"
  echo "- Temporary per-run logic: work/adapter-facts.shen"
  echo "- Expert raw flags: output/shen-output.txt"
  echo "- Rewrite path, only when needed: work/rewrite-patch.json -> work/rewrite.md -> output/rewrite-report.md"
}

render_source_frames() {
  local -a fact_files
  fact_files=()
  [[ -f "$FACTS" ]] && fact_files+=("$FACTS")
  [[ -f "$ADAPTER_FACTS" ]] && fact_files+=("$ADAPTER_FACTS")

  if [[ ${#fact_files[@]} -eq 0 ]]; then
    echo "- none"
    return
  fi

  awk '
    function strip_close(value) {
      sub(/\]$/, "", value)
      return value
    }
    function remember(id) {
      if (!(id in seen)) {
        seen[id] = 1
        order[++count] = id
      }
    }
    function quoted_text(line) {
      if (match(line, /"[^"]*"/)) {
        return substr(line, RSTART + 1, RLENGTH - 2)
      }
      return ""
    }
    /^[[:space:]]*\[definition[[:space:]]/ {
      id = $2
      text = quoted_text($0)
      if (text != "") {
        definition[id] = text
        remember(id)
      }
    }
    /^[[:space:]]*\[source-text[[:space:]]/ {
      id = $2
      text = quoted_text($0)
      if (text != "") {
        sourceText[id] = text
        remember(id)
      }
    }
    /^[[:space:]]*\[source-span[[:space:]]/ {
      id = $2
      end = strip_close($5)
      span[id] = $3 ":" $4 "-" end
      remember(id)
    }
    /^[[:space:]]*\[protected[[:space:]]/ {
      id = $2
      role[id] = strip_close($3)
      remember(id)
    }
    /^[[:space:]]*\[term[[:space:]]/ {
      id = $2
      termKind[id] = strip_close($3)
      remember(id)
    }
    /^[[:space:]]*\[claim[[:space:]]/ {
      id = $2
      shape[id] = strip_close($3) " claim"
      remember(id)
    }
    /^[[:space:]]*\[ground-claim[[:space:]]/ {
      id = $2
      shape[id] = "ground claim"
      remember(id)
    }
    /^[[:space:]]*\[conclusion[[:space:]]/ {
      id = $2
      shape[id] = "conclusion"
      remember(id)
    }
    /^[[:space:]]*\[value-conclusion[[:space:]]/ {
      id = $2
      shape[id] = "value conclusion"
      text = quoted_text($0)
      if (text != "") definition[id] = text
      remember(id)
    }
    END {
      for (i = 1; i <= count; i++) {
        id = order[i]
        text = sourceText[id] != "" ? sourceText[id] : definition[id]
        if (text == "" && role[id] == "" && shape[id] == "" && termKind[id] == "") {
          continue
        }
        label = id
        meta = ""
        if (role[id] != "") meta = meta (meta == "" ? "" : ", ") role[id]
        if (shape[id] != "") meta = meta (meta == "" ? "" : ", ") shape[id]
        else if (termKind[id] != "") meta = meta (meta == "" ? "" : ", ") termKind[id]
        if (span[id] != "") meta = meta (meta == "" ? "" : ", ") span[id]
        if (meta != "") label = label " (" meta ")"
        if (text != "") print "- " label ": " text
        else print "- " label
        printed++
      }
      if (printed == 0) print "- none"
    }
  ' "${fact_files[@]}"
}

render_diagnostic_frames() {
  local flags="$1"
  local -a fact_files
  fact_files=()
  [[ -f "$FACTS" ]] && fact_files+=("$FACTS")
  [[ -f "$ADAPTER_FACTS" ]] && fact_files+=("$ADAPTER_FACTS")

  if [[ ! -f "$flags" ]]; then
    echo "- No diagnostics yet."
    return
  fi

  awk -v flagfile="$flags" '
    function strip_close(value) {
      sub(/\]$/, "", value)
      return value
    }
    function quoted_text(line) {
      if (match(line, /"[^"]*"/)) {
        return substr(line, RSTART + 1, RLENGTH - 2)
      }
      return ""
    }
    function label(id) {
      if (id in sourceText) return "\"" sourceText[id] "\""
      if (id in definition) return "\"" definition[id] "\""
      return id
    }
    function loc(id) {
      if (id in span) return " Source: " span[id] "."
      return ""
    }
    function add(title, body) {
      print "- " title ": " body
      printed++
    }
    FILENAME != flagfile && /^[[:space:]]*\[definition[[:space:]]/ {
      id = $2
      text = quoted_text($0)
      if (text != "") definition[id] = text
      next
    }
    FILENAME != flagfile && /^[[:space:]]*\[source-text[[:space:]]/ {
      id = $2
      text = quoted_text($0)
      if (text != "") sourceText[id] = text
      next
    }
    FILENAME != flagfile && /^[[:space:]]*\[source-span[[:space:]]/ {
      id = $2
      end = strip_close($5)
      span[id] = $3 ":" $4 "-" end
      next
    }
    FILENAME != flagfile {
      next
    }
    FILENAME == flagfile {
      raw = $0
      if (raw == "" || raw == "[]") next
      line = raw
      sub(/^\[/, "", line)
      sub(/\]$/, "", line)
      n = split(line, parts, /[[:space:]]+/)
      head = parts[1]

      if (head == "plan-status" || head == "value-criteria-grounded" || head == "value-criteria-stated") next

      if (head == "fact-type-error") {
        add("Fact schema error", raw " Repair the fact shape, type, namespace, or schema version before judging the argument.")
      } else if (head == "fact-warning") {
        add("Fact schema warning", raw)
      } else if (head == "fact-suggestion") {
        add("Fact schema suggestion", raw)
      } else if (head == "fact-normalization") {
        add("Fact normalization", raw)
      } else if (head == "extraction-contract-violation") {
        add("Translation repair", parts[2] " is packed into a symbol Shen cannot inspect. Next: decompose it into typed facts." loc(parts[2]))
      } else if (head == "decomposition-needed") {
        add("Decomposition needed", parts[2] " should be represented as smaller predicates, not one compact term." loc(parts[2]))
      } else if (head == "definition-needed") {
        add("Definition needed", label(parts[2]) " needs an operational definition before the structure is clear." loc(parts[2]))
      } else if (head == "value-criteria-missing" || head == "value-criteria-needed") {
        add("Value criteria needed", label(parts[2]) " needs explicit criteria before the value judgment can be checked." loc(parts[2]))
      } else if (head == "missing-mechanism") {
        add("Mechanism missing", label(parts[2]) " needs a represented causal or operational bridge." loc(parts[2]))
      } else if (head == "mechanism-needs-causal-path") {
        add("Causal path needed", label(parts[2]) " needs intermediate source, process, effect, and outcome structure." loc(parts[2]))
      } else if (head == "missing-context") {
        add("Context missing", label(parts[2]) " relies on " parts[3] ", but that context is not known yet." loc(parts[2]))
      } else if (head == "claim-without-ground") {
        add("Support missing", label(parts[2]) " has no represented ground or support link." loc(parts[2]))
      } else if (head == "conclusion-stronger-than-ground") {
        add("Conclusion too strong", label(parts[3]) " is marked " parts[5] " while its ground is only " parts[4] ".")
      } else if (head == "conclusion-stronger-than-premises") {
        add("Conclusion too strong", label(parts[3]) " is marked " parts[5] " while a premise is only " parts[4] ".")
      } else if (head == "unclear-scope") {
        add("Scope unclear", label(parts[2]) " needs a local, section, document, global, or typed scope." loc(parts[2]))
      } else if (head == "unclear-modality") {
        add("Modality unclear", label(parts[2]) " needs a strength such as possible, probable, certain, recommendation, or requirement." loc(parts[2]))
      } else if (head == "stage-chain-too-short") {
        add("Mechanism stages too short", label(parts[2]) " has " parts[3] " stages; Shen expected at least " parts[4] ".")
      } else if (head == "missing-stage-bridge") {
        add("Stage bridge missing", label(parts[2]) " needs a bridge between " parts[3] " and " parts[4] ".")
      } else if (head == "scope-conflict") {
        add("Scope conflict", parts[2] " is " parts[4] " while " parts[3] " is " parts[5] ".")
      } else if (head == "context-conflict") {
        add("Context conflict", parts[2] " conflicts with " parts[3] ".")
      } else if (head == "contradiction") {
        add("Contradiction", raw)
      } else if (head == "tension") {
        add("Reconciliation tension", raw)
      } else if (head ~ /^deleted-/) {
        add("Rewrite deletion", raw " Restore the protected source commitment or mark it unresolved without removing it.")
      } else if (head ~ /-mutation$/) {
        add("Rewrite drift", raw " The rewrite changed a protected structural commitment.")
      } else if (head == "patch-violation" || head == "mutation-violation") {
        add("Rewrite safety violation", raw)
      } else if (head == "evidence-needed") {
        add("Evidence needed", parts[2] " needs support for " parts[3] ".")
      } else if (head == "precomputed-flag") {
        add("Kernel boundary violation", raw " Remove this derived result from input facts; Shen must derive it.")
      } else {
        add("Diagnostic", raw)
      }
    }
    END {
      if (printed == 0) print "- No blocking diagnostics in the default view."
    }
  ' "${fact_files[@]}" "$flags"
}

render_kernel_summary() {
  local flags="$1"
  if [[ ! -f "$flags" ]]; then
    echo "- Blocking issues: 0"
    echo "- Reconciliation tensions: 0"
    echo "- Mutation/deletion failures: 0"
    return
  fi
  awk '
    /^\[/ {
      if ($0 ~ /^\[fact-type-error / ||
          $0 ~ /^\[contradiction / ||
          $0 ~ /^\[definition-needed / ||
          $0 ~ /^\[missing-context / ||
          $0 ~ /^\[overclaim / ||
          $0 ~ /^\[deleted-/ ||
          $0 ~ /^\[mutation-violation / ||
          $0 ~ /^\[patch-violation /) blocking++
      if ($0 ~ /^\[tension / || $0 ~ /^\[mitigation-needs-equivalence-check /) tensions++
      if ($0 ~ /^\[deleted-/ || $0 ~ /^\[mutation-violation / || $0 ~ /^\[patch-violation /) mutation++
    }
    END {
      print "- Blocking issues: " (blocking + 0)
      print "- Reconciliation tensions: " (tensions + 0)
      print "- Mutation/deletion failures: " (mutation + 0)
    }
  ' "$flags"
}

render_check_report() {
  local dest="$1"
  local flags="$2"
  {
    echo "## Read first"
    echo
    render_kernel_summary "$flags"
    echo
    echo "## Next action"
    echo
    render_next_action "$flags"
    echo
    echo "## Diagnostics"
    echo
    render_diagnostic_frames "$flags"
    echo
    echo "## Open user tasks"
    echo
    render_open_user_tasks "$flags"
    echo
    echo "## Positive statuses"
    echo
    render_flag_category "$flags" positive
    echo
    echo "## Plan status"
    echo
    render_flag_category "$flags" status
    echo
    echo "## Source frames"
    echo
    render_source_frames
    echo
    echo "## File map"
    echo
    render_file_map
    echo
    echo "## Expert appendix: raw Shen flags"
    echo
    if [[ -s "$flags" ]]; then
      sed 's/^/- /' "$flags"
    else
      echo "- none"
    fi
    echo
    echo "## Expert appendix: source facts"
    echo
    render_fact_lines "$FACTS" source
    echo
    echo "## Expert appendix: user-supplied facts from gap answers"
    echo
    render_fact_lines "$FACTS" user
    echo
    echo "## Expert appendix: temporary adapter facts"
    echo
    if [[ -f "$ADAPTER_FACTS" ]]; then
      render_fact_lines "$ADAPTER_FACTS" adapter
    else
      echo "- none"
    fi
  } > "$dest"
}

assert_line() {
  local file="$1"
  local expected="$2"
  local label="$3"
  if ! grep -Fxq -- "$expected" "$file"; then
    echo "FAIL $label"
    echo "  expected line: $expected"
    echo "  actual output:"
    sed 's/^/    /' "$file"
    return 1
  fi
}

assert_no_text() {
  local file="$1"
  local forbidden="$2"
  local label="$3"
  if grep -Fq -- "$forbidden" "$file"; then
    echo "FAIL $label"
    echo "  forbidden text: $forbidden"
    echo "  actual output:"
    sed 's/^/    /' "$file"
    return 1
  fi
}

case "${1:-help}" in
  review)
    ensure_dirs
    shift || true
    "$0" check "$@" > "$OUT/.shen-review-raw-output.txt"
    cat "$CHECK_REPORT"
    ;;
  preflight)
    ensure_dirs
    if ! use_legacy_js_preflight "$@" && [[ ! -x "$SHEN" ]]; then
      echo "Could not find shen-sbcl at: $SHEN" >&2
      echo "Set SHEN_SBCL=/path/to/shen-sbcl and try again." >&2
      exit 1
    fi
    if use_legacy_js_preflight "$@"; then
      typeset -a preflight_files
      preflight_files=("$FACTS")
      if [[ -f "$ADAPTER_FACTS" ]]; then
        preflight_files+=("$ADAPTER_FACTS")
      fi
      node "$ROOT/scripts/preflight-facts.js" "${preflight_files[@]}" > "$PREFLIGHT_FACTS"
    else
      run_native_preflight "$PREFLIGHT_FACTS" -l "$FACTS"
    fi
    cat "$PREFLIGHT_FACTS"
    ;;
  check)
    ensure_dirs
    typeset -a adapter_args legacy_preflight_args
    adapter_args=()
    legacy_preflight_args=()
    if [[ -f "$ADAPTER_FACTS" ]]; then
      adapter_args=(-l "$ADAPTER_FACTS")
    fi
    if [[ ! -x "$SHEN" ]]; then
      echo "Could not find shen-sbcl at: $SHEN" >&2
      echo "Set SHEN_SBCL=/path/to/shen-sbcl and try again." >&2
      exit 1
    fi
    if use_legacy_js_preflight "$@"; then
      typeset -a preflight_files
      preflight_files=("$FACTS")
      if [[ -f "$ADAPTER_FACTS" ]]; then
        preflight_files+=("$ADAPTER_FACTS")
      fi
      node "$ROOT/scripts/preflight-facts.js" "${preflight_files[@]}" > "$PREFLIGHT_FACTS"
      legacy_preflight_args=(-l "$PREFLIGHT_FACTS")
    fi
    "$SHEN" \
      -l "$FACTS" \
      "${SCHEMA_ARGS[@]}" \
      -l "$ROOT/shen/rules.shen" \
      "${adapter_args[@]}" \
      "${legacy_preflight_args[@]}" \
      -l "$ROOT/shen/run.shen" \
      > "$OUT/.shen-raw-output.txt"
    capture_logicbox_output "$OUT/.shen-raw-output.txt" "$OUT/shen-output.txt"
    render_check_report "$CHECK_REPORT" "$OUT/shen-output.txt"
    cat "$OUT/shen-output.txt"
    ;;
  mutation)
    ensure_dirs
    typeset -a adapter_args legacy_preflight_args
    adapter_args=()
    legacy_preflight_args=()
    if [[ -f "$ADAPTER_FACTS" ]]; then
      adapter_args=(-l "$ADAPTER_FACTS")
    fi
    if [[ ! -x "$SHEN" ]]; then
      echo "Could not find shen-sbcl at: $SHEN" >&2
      echo "Set SHEN_SBCL=/path/to/shen-sbcl and try again." >&2
      exit 1
    fi
    if use_legacy_js_preflight "$@"; then
      typeset -a preflight_files
      preflight_files=("$FACTS" "$REWRITE_FACTS")
      if [[ -f "$ADAPTER_FACTS" ]]; then
        preflight_files+=("$ADAPTER_FACTS")
      fi
      node "$ROOT/scripts/preflight-facts.js" "${preflight_files[@]}" > "$PREFLIGHT_FACTS"
      legacy_preflight_args=(-l "$PREFLIGHT_FACTS")
    fi
    "$SHEN" \
      -l "$FACTS" \
      -l "$REWRITE_FACTS" \
      "${SCHEMA_ARGS[@]}" \
      -l "$ROOT/shen/rules.shen" \
      "${adapter_args[@]}" \
      "${legacy_preflight_args[@]}" \
      -l "$ROOT/shen/run-mutation.shen" \
      > "$OUT/.shen-mutation-raw-output.txt"
    capture_logicbox_output "$OUT/.shen-mutation-raw-output.txt" "$OUT/mutation-output.txt"
    cat "$OUT/mutation-output.txt"
    ;;
  rewrite-preflight)
    ensure_dirs
    node "$ROOT/scripts/rewrite-safety.js" validate-patch \
      --draft "$WORK/draft.txt" \
      --patch "$REWRITE_PATCH" \
      $(rewrite_safety_args "$@")
    ;;
  rewrite)
    ensure_dirs
    mode="$(node -e 'const fs=require("fs"); const p=JSON.parse(fs.readFileSync(process.argv[1],"utf8")); console.log(p.mode||"structure_only")' "$REWRITE_PATCH")"
    if [[ "$mode" == "rewrite_with_user_facts" && -f "$OUT/shen-output.txt" ]]; then
      cp "$OUT/shen-output.txt" "$SHEN_BEFORE_REWRITE"
    elif [[ "$mode" == "rewrite_with_user_facts" ]]; then
      : > "$SHEN_BEFORE_REWRITE"
    fi
    if [[ "$mode" == "rewrite_with_user_facts" ]]; then
      node "$ROOT/scripts/rewrite-safety.js" run \
        --draft "$WORK/draft.txt" \
        --patch "$REWRITE_PATCH" \
        --rewrite "$REWRITE" \
        --report "$REWRITE_REPORT" \
        $(rewrite_safety_args "$@") \
        > "$OUT/.rewrite-apply-report.txt"
    else
      node "$ROOT/scripts/rewrite-safety.js" run \
        --draft "$WORK/draft.txt" \
        --patch "$REWRITE_PATCH" \
        --rewrite "$REWRITE" \
        --report "$REWRITE_REPORT" \
        $(rewrite_safety_args "$@")
    fi
    if [[ "$mode" == "rewrite_with_user_facts" ]]; then
      node "$ROOT/scripts/rewrite-safety.js" mutation \
        --draft "$WORK/draft.txt" \
        --rewrite "$REWRITE" \
        --patch "$REWRITE_PATCH" \
        $(rewrite_safety_args "$@") \
        > "$OUT/mutation-output.txt"
      if [[ ! -x "$SHEN" ]]; then
        echo "Could not find shen-sbcl at: $SHEN" >&2
        echo "Set SHEN_SBCL=/path/to/shen-sbcl and try again." >&2
        exit 1
      fi
      typeset -a adapter_args
      adapter_args=()
      if [[ -f "$ADAPTER_FACTS" ]]; then
        adapter_args=(-l "$ADAPTER_FACTS")
      fi
      "$SHEN" \
        -l "$FACTS" \
        "${SCHEMA_ARGS[@]}" \
        -l "$ROOT/shen/rules.shen" \
        "${adapter_args[@]}" \
        -l "$ROOT/shen/run.shen" \
        > "$OUT/.shen-raw-output.txt"
      capture_logicbox_output "$OUT/.shen-raw-output.txt" "$OUT/shen-output.txt"
      render_check_report "$CHECK_REPORT" "$OUT/shen-output.txt"
      node "$ROOT/scripts/rewrite-safety.js" recheck-report \
        --patch "$REWRITE_PATCH" \
        --rewrite "$REWRITE" \
        --before "$SHEN_BEFORE_REWRITE" \
        --after "$OUT/shen-output.txt" \
        --mutation "$OUT/mutation-output.txt" \
        --report "$REWRITE_REPORT"
    fi
    ;;
  rewrite-mutation)
    ensure_dirs
    node "$ROOT/scripts/rewrite-safety.js" mutation \
      --draft "$WORK/draft.txt" \
      --rewrite "$REWRITE" \
      --patch "$REWRITE_PATCH" \
      $(rewrite_safety_args "$@") \
      > "$REWRITE_REPORT"
    cat "$REWRITE_REPORT"
    ;;
  recheck-report)
    ensure_dirs
    node "$ROOT/scripts/rewrite-safety.js" recheck-report \
      --patch "$REWRITE_PATCH" \
      --rewrite "$REWRITE" \
      --before "$SHEN_BEFORE_REWRITE" \
      --after "$OUT/shen-output.txt" \
      --mutation "$OUT/mutation-output.txt" \
      --report "$REWRITE_REPORT"
    ;;
  rewrite-test)
    ensure_dirs
    node "$ROOT/scripts/rewrite-safety.js" test
    ;;
  report-smoke)
    ensure_dirs
    tmpdir="$(mktemp -d /tmp/logicbox-report.XXXXXX)"
    trap 'rm -rf "$tmpdir"' EXIT
    FACTS="$tmpdir/facts.shen"
    ADAPTER_FACTS="$tmpdir/adapter-facts.shen"
    flags="$tmpdir/flags.txt"
    report="$tmpdir/check-report.md"
    cat > "$FACTS" <<'EOF'
(set *facts*
  [
    [plan p1]
    [plan-source p1 draft]
    [term c1 claim]
    [source-text c1 "The draft makes a claim."]
    [source-span c1 draft 1 1]
    [definition c1 "The draft makes a claim."]
  ])
EOF
    cat > "$ADAPTER_FACTS" <<'EOF'
(set *adapter-facts*
  [
  ])
EOF
    cat > "$flags" <<'EOF'
[missing-context c1 assumption]
[plan-status p1 needs-user-input]
EOF
    render_check_report "$report" "$flags"
    assert_line "$report" "## Diagnostics" "report includes diagnostics section"
    assert_line "$report" "- Context missing: \"The draft makes a claim.\" relies on assumption, but that context is not known yet. Source: draft:1-1." "diagnostic uses source frame"
    assert_line "$report" "## File map" "report includes file map"
    echo "ok"
    ;;
  schema-test)
    ensure_dirs
    "$SHEN" \
      "${SCHEMA_ARGS[@]}" \
      -l "$ROOT/shen/fact-regression.shen" \
      -l "$ROOT/shen/run-fact-regression.shen" \
      > "$OUT/.shen-schema-regression-raw-output.txt"
    capture_logicbox_output "$OUT/.shen-schema-regression-raw-output.txt" "$OUT/.shen-schema-regression-output.txt"
    cat "$OUT/.shen-schema-regression-output.txt"
    if grep -Fq -- "FAIL" "$OUT/.shen-schema-regression-output.txt"; then
      exit 1
    fi
    ;;
  schema-contract)
    ensure_dirs
    "$SHEN" \
      "${SCHEMA_ARGS[@]}" \
      -l "$ROOT/shen/run-prompt-contract.shen" \
      > "$OUT/.shen-schema-contract-raw-output.txt"
    capture_logicbox_output "$OUT/.shen-schema-contract-raw-output.txt" "$OUT/schema-contract.shen"
    cat "$OUT/schema-contract.shen"
    ;;
  test)
    ensure_dirs
    for model in "$ROOT"/tests/*-model.shen; do
      echo "${model:t}:"
      "$SHEN" \
        -l "$model" \
        "${SCHEMA_ARGS[@]}" \
        -l "$ROOT/shen/rules.shen" \
        -l "$ROOT/shen/run.shen" \
        > "$OUT/.shen-test-raw-output.txt"
      awk '
        /^LOGICBOX-BEGIN$/ {capture=1; next}
        /^LOGICBOX-END$/ {capture=0; exit}
        capture && $0 !~ /^"/ && $0 != "ok" {print}
      ' "$OUT/.shen-test-raw-output.txt"
      echo
    done
    echo "gold:"
    "$0" gold
    echo "edge:"
    "$0" edge
    echo "fuzz:"
    "$0" fuzz
    echo "rewrite-test:"
    "$0" rewrite-test
    echo "report-smoke:"
    "$0" report-smoke
    echo "schema-test:"
    "$0" schema-test
    ;;
  stress)
    ensure_dirs
    for model in "$ROOT"/tests/stress-*-model.shen; do
      echo "${model:t}:"
      "$SHEN" \
        -l "$model" \
        "${SCHEMA_ARGS[@]}" \
        -l "$ROOT/shen/rules.shen" \
        -l "$ROOT/shen/run.shen" \
        > "$OUT/.shen-stress-raw-output.txt"
      capture_logicbox_output "$OUT/.shen-stress-raw-output.txt" "$OUT/.shen-stress-output.txt"
      cat "$OUT/.shen-stress-output.txt"
      echo
    done
    ;;
  gold)
    ensure_dirs
    failures=0
    for model in "$ROOT"/tests/gold/*.shen(N); do
      expected="${model:r}.expected"
      out="$OUT/.shen-gold-output.txt"
      raw="$OUT/.shen-gold-raw-output.txt"
      echo "${model:t}:"
      run_check_model "$model" "$raw" "$out"
      if [[ ! -f "$expected" ]]; then
        echo "FAIL missing expected file: $expected"
        failures=$((failures + 1))
      elif ! diff -u "$expected" "$out"; then
        failures=$((failures + 1))
      else
        echo "ok"
      fi
      echo
    done
    if [[ $failures -gt 0 ]]; then
      echo "$failures gold test(s) failed." >&2
      exit 1
    fi
    ;;
  edge)
    ensure_dirs
    failures=0
    for model in "$ROOT"/tests/edge/*.shen(N); do
      expected="${model:r}.expected"
      out="$OUT/.shen-edge-output.txt"
      raw="$OUT/.shen-edge-raw-output.txt"
      echo "${model:t}:"
      run_check_model "$model" "$raw" "$out"
      if [[ ! -f "$expected" ]]; then
        echo "FAIL missing expected file: $expected"
        failures=$((failures + 1))
      elif ! diff -u "$expected" "$out"; then
        failures=$((failures + 1))
      else
        echo "ok"
      fi
      echo
    done
    if [[ $failures -gt 0 ]]; then
      echo "$failures edge test(s) failed." >&2
      exit 1
    fi
    ;;
  fuzz)
    ensure_dirs
    tmpdir="$(mktemp -d /tmp/logicbox-fuzz.XXXXXX)"
    trap 'rm -rf "$tmpdir"' EXIT
    failures=0

    run_fuzz() {
      local name="$1"
      local model="$tmpdir/$name.shen"
      local out="$tmpdir/$name.out"
      local raw="$tmpdir/$name.raw"
      shift
      "$@" > "$model"
      run_check_model "$model" "$raw" "$out"
      print -r -- "$out"
    }

    write_scope_same_model() {
      cat <<'EOF'
(set *facts*
  [
    [plan p1]
    [plan-source p1 fuzz]
    [plan-goal p1 invariant-check]
    [plan-fact p1 f1]
    [plan-fact p1 f2]
    [fact-scope f1 local]
    [fact-scope f2 local]
    [scope-conflict-candidate f1 f2]
    [scope-incompatible global local]
  ])
EOF
    }

    write_stage_model() {
      local count="$1"
      {
        print "(set *facts*"
        print "  ["
        print "    [plan p1]"
        print "    [plan-source p1 fuzz]"
        print "    [plan-goal p1 stage-chain]"
        print "    [term source known]"
        print "    [term target known]"
        print "    [claim c1 causal source target]"
        print "    [mechanism c1 bridge]"
        print "    [modality c1 possible]"
        print "    [scope c1 conditional]"
        print "    [stage-chain-min c1 3]"
        if [[ "$count" -gt 0 ]]; then
          for i in $(seq 1 "$count"); do
            print "    [stage s$i step-$i]"
            print "    [stage-of s$i c1]"
            print "    [stage-order s$i $i]"
          done
        fi
        print "  ])"
      }
    }

    write_context_model() {
      local state="$1"
      cat <<EOF
(set *facts*
  [
    [plan p1]
    [plan-source p1 fuzz]
    [plan-goal p1 context-obligation]
    [term feedback known]
    [term improvement known]
    [claim c1 causal feedback improvement]
    [mechanism c1 learning]
    [modality c1 possible]
    [scope c1 conditional]
    [context-required c1 feedback-reliable]
    [context-known feedback-reliable $state]
  ])
EOF
    }

    write_ground_model() {
      local conclusion_modality="$1"
      cat <<EOF
(set *facts*
  [
    [plan p1]
    [plan-source p1 fuzz]
    [plan-goal p1 ground-strength]
    [ground-claim g1 source support]
    [modality g1 probable]
    [conclusion k1 target]
    [modality k1 $conclusion_modality]
    [infers-to g1 k1]
    [stronger-than certain probable]
  ])
EOF
    }

    write_mutation_model() {
      local mutation="$1"
      case "$mutation" in
        modality)
          cat <<'EOF'
(set *facts*
  [
    [plan p1]
    [claim c1 causal source target]
    [mechanism c1 bridge]
    [modality c1 possible]
    [scope c1 conditional]
    [rewrite-claim r1 causal source target]
    [rewrite-modality r1 certain]
    [rewrite-scope r1 conditional]
    [stronger-than certain possible]
  ])
EOF
          ;;
        scope)
          cat <<'EOF'
(set *facts*
  [
    [plan p1]
    [claim c1 causal source target]
    [mechanism c1 bridge]
    [modality c1 possible]
    [scope c1 conditional]
    [rewrite-claim r1 causal source target]
    [rewrite-modality r1 possible]
    [rewrite-scope r1 universal]
    [stronger-than universal conditional]
  ])
EOF
          ;;
      esac
    }

    echo "fuzz-scope-identical:"
    out="$(run_fuzz scope-identical write_scope_same_model)"
    assert_line "$out" "[plan-status p1 ready-for-final-rewrite]" "identical scopes should be clear" || failures=$((failures + 1))
    assert_no_text "$out" "[scope-conflict" "identical scopes should not conflict" || failures=$((failures + 1))

    for count in 0 1 2 3 4; do
      echo "fuzz-stage-count-$count:"
      out="$(run_fuzz stage-count-$count write_stage_model "$count")"
      if [[ "$count" -lt 3 ]]; then
        assert_line "$out" "[stage-chain-too-short c1 $count 3]" "stage count $count should be too short" || failures=$((failures + 1))
        assert_line "$out" "[plan-status p1 needs-user-input]" "short stage count should be incomplete" || failures=$((failures + 1))
      else
        assert_no_text "$out" "[stage-chain-too-short" "stage count $count should not be too short" || failures=$((failures + 1))
        assert_line "$out" "[plan-status p1 ready-for-final-rewrite]" "stage count $count should be clear" || failures=$((failures + 1))
      fi
    done

    for state in known unknown; do
      echo "fuzz-context-$state:"
      out="$(run_fuzz context-$state write_context_model "$state")"
      if [[ "$state" == "unknown" ]]; then
        assert_line "$out" "[missing-context c1 feedback-reliable]" "unknown context should be missing" || failures=$((failures + 1))
      else
        assert_no_text "$out" "[missing-context" "known context should not be missing" || failures=$((failures + 1))
        assert_line "$out" "[plan-status p1 ready-for-final-rewrite]" "known context should be clear" || failures=$((failures + 1))
      fi
    done

    for modality in probable certain; do
      echo "fuzz-ground-$modality:"
      out="$(run_fuzz ground-$modality write_ground_model "$modality")"
      if [[ "$modality" == "certain" ]]; then
        assert_line "$out" "[conclusion-stronger-than-ground g1 k1 probable certain]" "certain conclusion should outrun probable ground" || failures=$((failures + 1))
      else
        assert_no_text "$out" "[conclusion-stronger-than-ground" "matching modality should not outrun ground" || failures=$((failures + 1))
        assert_line "$out" "[plan-status p1 ready-for-final-rewrite]" "matching modality should be clear" || failures=$((failures + 1))
      fi
    done

    for mutation in modality scope; do
      echo "fuzz-mutation-$mutation:"
      out="$(run_fuzz mutation-$mutation write_mutation_model "$mutation")"
      case "$mutation" in
        modality)
          assert_line "$out" "[modality-mutation c1 r1 possible certain]" "modality mutation should be caught" || failures=$((failures + 1))
          ;;
        scope)
          assert_line "$out" "[scope-mutation c1 r1 conditional universal]" "scope mutation should be caught" || failures=$((failures + 1))
          ;;
      esac
    done

    if [[ $failures -gt 0 ]]; then
      echo "$failures fuzz invariant(s) failed." >&2
      exit 1
    fi
    echo "All fuzz invariants passed."
    ;;
  new)
    ensure_dirs
    shift || true
    if [[ $# -eq 0 ]]; then
      echo "Please provide the draft text." >&2
      exit 1
    fi
    printf '%s\n' "$*" > "$WORK/draft.txt"
    cat > "$FACTS" <<'EOF'
\\ AI fills this with candidate facts. Do not put derived flags here.
\\ Run ./logicbox review after editing.

(set *facts*
  [
    [plan p1]
    [plan-source p1 draft-1]
    [plan-goal p1 clarify-argument]
    [plan-fact p1 f-example-term]
    [plan-fact p1 f-example-result]
    [plan-check p1 definition-needed]
    [comment p1 "AI should replace this starter plan with extracted facts."]

    [term example-term unknown]
    [claim c1 assertion example-term example-result]
    [term example-result unknown]
    [mechanism c1 unknown]
    [modality c1 unknown]
    [scope c1 unknown]

    [fact-scope f-example-term local]
    [fact-scope f-example-result local]
  ])
EOF
    cat > "$ADAPTER_FACTS" <<'EOF'
\\ Temporary AI semantic bridge facts for the current run.
\\ Keep this empty unless a draft/user answer needs a bridge such as
\\ [implies Y X], [denies Y X], [conflicts Y X], or [undermines Y X].

(set *adapter-facts*
  [
  ])

(set *facts*
  (append (value *facts*) (value *adapter-facts*)))
EOF
    echo "Created work/draft.txt, starter work/ai-facts.shen, and empty work/adapter-facts.shen."
    ;;
  show)
    ensure_dirs
    echo "Draft:"
    sed -n '1,120p' "$WORK/draft.txt"
    echo
    echo "AI facts:"
    sed -n '1,220p' "$FACTS"
    echo
    echo "Adapter facts:"
    [[ -f "$ADAPTER_FACTS" ]] && sed -n '1,220p' "$ADAPTER_FACTS" || true
    echo
    echo "Last Shen output:"
    [[ -f "$OUT/shen-output.txt" ]] && sed -n '1,220p' "$OUT/shen-output.txt" || true
    echo
    echo "Last check report:"
    [[ -f "$CHECK_REPORT" ]] && sed -n '1,220p' "$CHECK_REPORT" || true
    echo
    echo "Last mutation output:"
    [[ -f "$OUT/mutation-output.txt" ]] && sed -n '1,220p' "$OUT/mutation-output.txt" || true
    echo
    echo "Last rewrite report:"
    [[ -f "$REWRITE_REPORT" ]] && sed -n '1,220p' "$REWRITE_REPORT" || true
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac
