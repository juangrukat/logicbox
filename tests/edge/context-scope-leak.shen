(set *facts*
  [
    [plan p1]
    [plan-source p1 edge-context]
    [plan-goal p1 context-scope-leak]
    [plan-claim p1 c1]
    [term feedback known]
    [term improvement known]
    [claim c1 causal feedback improvement]
    [mechanism c1 learning]
    [modality c1 possible]
    [scope c1 conditional]
    [context-required c1 feedback-reliable]
    [context-known feedback-reliable known]
    [context-scope feedback-reliable local]
    [context-required-scope c1 feedback-reliable global]
    [scope-incompatible local global]
  ])
