(set *facts*
  [
    [plan p1]
    [plan-source p1 edge-stage]
    [plan-goal p1 paraphrased-mechanism]
    [term source known]
    [term target known]
    [claim c1 causal source target]
    [mechanism c1 identify-patterns]
    [modality c1 possible]
    [scope c1 conditional]
    [stage-chain-min c1 1]
    [stage s1 pattern-detection]
    [stage-of s1 c1]
    [stage-order s1 1]
    [similar identify-patterns pattern-detection]
  ])
