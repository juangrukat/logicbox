(set *facts*
  [
    [plan p1]
    [plan-source p1 edge-value-conclusion]
    [plan-goal p1 value-criteria]
    [plan-fact p1 k1]

    [term c1 claim]
    [action c1 introduce]
    [target c1 ai-triage]

    [term k1 value-conclusion]
    [value-type k1 fairness]
    [applies-to k1 c1]
    [criteria-status k1 unspecified]
    [fact-scope k1 local]
  ])
